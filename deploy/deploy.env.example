REMOTE_HOST=192.168.1.101
REMOTE_USER=box
REMOTE_PORT=22
REMOTE_APP_DIR=/home/box/tradingagents-ashare
REMOTE_API_SERVICE=tradingagents-api
REMOTE_TUNNEL_SERVICE=tradingagents-cloudflared-quick

# Optional: only needed if your SSH/SCP still uses password auth.
REMOTE_PASSWORD=
REMOTE_SUDO_PASSWORD=

# Optional: copy a local env file to the remote host before restart.
SYNC_REMOTE_ENV=0
LOCAL_REMOTE_ENV_FILE=
REMOTE_ENV_FILE=/home/box/tradingagents-ashare/.env.production

# Frontend / Vercel
FRONTEND_DIR=frontend
FRONTEND_SITE_URL=https://frontend-smoky-pi-69.vercel.app

